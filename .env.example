# ── LUMIVAO — variables d'environnement ──────────────────────────────
# Copiez ce fichier en .env.local et remplissez les valeurs.

# URL publique de l'application (utilisée pour les liens partageables et QR)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI — UNIQUEMENT côté serveur. Ne jamais préfixer par NEXT_PUBLIC_.
# Si absente, LUMIVAO bascule automatiquement sur les modèles d'offres locaux.
OPENAI_API_KEY=
# Modèle économique par défaut (modifiable)
OPENAI_MODEL=gpt-4o-mini

# Supabase / PostgreSQL (optionnel pour le mode démo localStorage)
DATABASE_URL=
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
